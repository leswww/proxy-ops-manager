# =====================================================
# ProxyOps Manager 本地开发环境变量示例
# 复制为 .env 后再修改：
#   cp .env.example .env
# 注意：本文件只能含占位符 / 演示值，禁止写入真实凭据。
# =====================================================

# ── 数据库 ──────────────────────────────────────────
DATABASE_PROVIDER="mysql"
DATABASE_URL="mysql://ipops_user:change_me@127.0.0.1:3306/proxy_ops_manager"

# ── 管理员账号 ──────────────────────────────────────
ADMIN_USERNAME="admin"
# ADMIN_PASSWORD_HASH 必须是 bcrypt 哈希字符串。
# 留空时仅在 USE_MOCK_DATA=true 的演示模式下可用 admin / admin123 登录。
# 生成方式：
#   node -e "console.log(require('bcryptjs').hashSync('your-password',12))"
ADMIN_PASSWORD_HASH=""

# ── 会话密钥 (至少 32 位随机字符串) ────────────────
SESSION_SECRET="change_me_random_secret_at_least_32_chars"

# ── 应用 ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="ProxyOps Manager"
NEXT_PUBLIC_APP_DOMAIN="your-domain.com"

# ── 演示模式 ──────────────────────────────────────
# true 时使用内置 mock 数据，无需 MySQL。仅供本地开发使用。
USE_MOCK_DATA="true"
NEXT_PUBLIC_USE_MOCK_DATA="true"

# ── 运行时 ────────────────────────────────────────────
NODE_ENV="development"
APP_PORT="3010"
PORT="3010"
