# =====================================================
# ProxyOps Manager 生产环境变量示例
# 部署时复制为 .env.production 后再修改：
#   cp .env.production.example .env.production
#
# 重要：
# - install.sh 会自动生成数据库密码、SESSION_SECRET、管理员临时密码
#   及 ADMIN_PASSWORD_HASH，无需手动填写。
# - 如手动部署，需要自己生成 bcrypt hash，例如：
#     node -e "console.log(require('bcryptjs').hashSync('your-password',12))"
# - ADMIN_PASSWORD_HASH 内含 $，shell source 加载请使用单引号包裹，
#   或改用 Node/PM2 直接解析 env，避免 $ 被 shell 展开。
# - 严禁把真实密钥提交到仓库。
# =====================================================

NODE_ENV="production"
APP_PORT="3010"
PORT="3010"

# ── 数据库 ──────────────────────────────────────────
DATABASE_PROVIDER="mysql"
DATABASE_URL="mysql://ipops_user:change_me@127.0.0.1:3306/proxy_ops_manager"

# ── 管理员账号 ──────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH=""

# ── 会话密钥 (至少 32 位随机字符串) ────────────────
SESSION_SECRET="change_me_random_secret"

# ── 演示模式 ──────────────────────────────────────
# 生产环境必须为 false
USE_MOCK_DATA="false"

# ── 应用 ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="ProxyOps Manager"
NEXT_PUBLIC_APP_DOMAIN="your-domain.com"
